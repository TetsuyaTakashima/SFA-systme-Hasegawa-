# Vercel Project Settings > Environment Variables に登録する値の控えです。
# 現在の静的HTML版は未設定でも localStorage 保存で動作します。
# Supabase同期を有効化する実装フェーズで、公開可能な anon key だけをブラウザ側に渡します。

SUPABASE_URL=
SUPABASE_ANON_KEY=

# 任意。外部ドメインから /api/proxy を読む必要がある場合だけ設定します。
# 通常のVercel同一オリジン配信では未設定で問題ありません。
ALLOWED_ORIGIN=https://your-kabu-web.example.com

# 任意。正式マーケットデータAPIへ切り替える場合に設定します。
# MARKET_DATA_PROVIDER は polygon または alpha_vantage を指定します。
MARKET_DATA_PROVIDER=
POLYGON_API_KEY=
ALPHA_VANTAGE_API_KEY=

# サーバー側ジョブ・Edge Functions 専用。ブラウザ、Git、チャットには出さないでください。
SUPABASE_SERVICE_ROLE_KEY=
